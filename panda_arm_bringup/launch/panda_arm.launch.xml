<launch>
    <let name="urdf_path"
        value="$(find-pkg-share arm_description)/urdf/panda_arm.urdf.xacro"/>

    <let name="rviz_config_path"
        value="$(find-pkg-share panda_arm_bringup)/config/moveit.rviz"/>

    <!-- <node pkg="robot_state_publisher" exec="robot_state_publisher">
            <param name="robot_description"
                value="$(command 'xacro $(var urdf_path)')" />
    </node> -->

    <node pkg="controller_manager" exec="ros2_control_node">
        <param from="$(find-pkg-share panda_arm_bringup)/config/ros2_controllers.yaml"/>
    </node>

    <node pkg="controller_manager" exec="spawner" output="screen"
        args="joint_state_broadcaster --controller-manager /controller_manager"/>
    <node pkg="controller_manager" exec="spawner" output="screen"
        args="arm_controller --controller-manager /controller_manager"/>
    <node pkg="controller_manager" exec="spawner" output="screen"
        args="gripper_controller --controller-manager /controller_manager"/>

    <include file="$(find-pkg-share arm_moveit_config)/launch/move_group.launch.py" />

    <node pkg="rviz2" exec="rviz2" output="screen" 
            args="-d $(var rviz_config_path)" />

</launch>